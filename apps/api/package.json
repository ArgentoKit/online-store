    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@faker-js/faker": "^10.3.0",
